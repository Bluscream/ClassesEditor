<UserControl x:Class="ClassesEditor.UI.Views.AssociationDetailView_Protocol"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DesignHeight="400" d:DesignWidth="400">
    <StackPanel Margin="20">
        <TextBlock Text="Key Name:" FontWeight="Bold" />
        <TextBox Text="{Binding AssociationName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,10" />
        <TextBlock Text="Association Details" FontWeight="Bold" FontSize="16" Margin="0,0,0,10" />
        <TextBlock Text="Registry Path:" FontWeight="Bold" />
        <TextBlock Text="{Binding RegistryPath}" FontFamily="Consolas" Margin="0,0,0,10" />
        <TextBlock Text="Display Name:" />
        <TextBox Text="{Binding DisplayName, Mode=TwoWay}" Margin="0,0,0,10" />
        <TextBlock Text="Default Icon:" />
        <TextBox Text="{Binding DefaultIcon, Mode=TwoWay}" Margin="0,0,0,10" />
        <TextBlock Text="Open Command:" />
        <TextBox Text="{Binding OpenCommand, Mode=TwoWay}" Margin="0,0,0,10" />
        <TextBlock Text="Info Tip:" />
        <TextBox Text="{Binding InfoTip, Mode=TwoWay}" Margin="0,0,0,10" />
        <TextBlock Text="Open With List (executables):" />
        <StackPanel Orientation="Horizontal">
            <TextBox x:Name="OpenWithExeBox" Width="150" />
            <Button Content="Add" Width="40" Margin="5,0,0,0" Click="AddOpenWith_Click" />
        </StackPanel>
        <ListBox ItemsSource="{Binding OpenWithList}" Height="60" Margin="0,0,0,10" SelectionMode="Single" x:Name="OpenWithListBox" />
        <Button Content="Remove Selected" Width="120" Click="RemoveOpenWith_Click" />
        <TextBlock Text="Open With ProgIDs:" Margin="0,10,0,0" />
        <StackPanel Orientation="Horizontal">
            <TextBox x:Name="OpenWithProgidBox" Width="150" />
            <Button Content="Add" Width="40" Margin="5,0,0,0" Click="AddOpenWithProgid_Click" />
        </StackPanel>
        <ListBox ItemsSource="{Binding OpenWithProgids}" Height="60" Margin="0,0,0,10" SelectionMode="Single" x:Name="OpenWithProgidListBox" />
        <Button Content="Remove Selected" Width="120" Click="RemoveOpenWithProgid_Click" />
        <StackPanel Orientation="Horizontal" Margin="0,10,0,0">
            <Button Content="Save" Width="80" Margin="0,0,10,0" Command="{Binding SaveCommand}" />
            <Button Content="Delete" Width="80" Margin="0,0,10,0" Command="{Binding DeleteCommand}" Background="Tomato" Foreground="White" />
            <Button Content="Open in Regedit" Width="120" Click="OpenInRegedit_Click" />
        </StackPanel>
    </StackPanel>
</UserControl> 